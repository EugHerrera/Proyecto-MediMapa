# Fase de build: compilación estricta y empaquetado
FROM eclipse-temurin:21-jdk-jammy AS build

WORKDIR /app

# Copiamos solo el pom y el código fuente
COPY pom.xml .
COPY src ./src

# Instalamos Maven nativo y las dependencias de Playwright necesarias para el build
RUN apt-get update && apt-get install -y \
    maven \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    && rm -rf /var/lib/apt/lists/*

# Quality Gate: build completo y empaquetado sin omitir pruebas
RUN mvn clean package
RUN cp target/*.jar app.jar

# Instalamos los navegadores de Playwright si el proyecto lo requiere
RUN mvn exec:java -e -Dexec.mainClass=com.microsoft.playwright.CLI -Dexec.args="install --with-deps"

# Fase de runtime: solo el artefacto empaquetado
FROM eclipse-temurin:21-jre-jammy
WORKDIR /app
COPY --from=build /app/app.jar /app/app.jar
ENTRYPOINT ["java", "-jar", "/app/app.jar"]