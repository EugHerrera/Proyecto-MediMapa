{
  "info": {
    "name": "ms-medimapa Integration Tests",
    "description": "Pruebas específicas para el microservicio Medimapa scraper.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://api-gateway:8080"
    }
  ],
  "item": [
    {
      "name": "GET precios scraper en medimapa",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/scraper/precios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "scraper",
            "precios"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is valid JSON array', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
