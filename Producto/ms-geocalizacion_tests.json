{
  "info": {
    "name": "ms-geocalizacion Integration Tests",
    "description": "Pruebas específicas para ms-geocalizacion usando Newman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://api-gateway:8080"
    }
  ],
  "item": [
    {
      "name": "GET sucursales cercanas en ms-geocalizacion",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/geolocalizacion/sucursales?lat=-33.45&lon=-70.65&radio=1000",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "geolocalizacion",
            "sucursales"
          ],
          "query": [
            {
              "key": "lat",
              "value": "-33.45"
            },
            {
              "key": "lon",
              "value": "-70.65"
            },
            {
              "key": "radio",
              "value": "1000"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is valid JSON array', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
