{
  "info": {
    "name": "ms-usuarios Integration Tests",
    "description": "Pruebas específicas para ms-usuarios usando Newman.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://api-gateway:8080"
    },
    {
      "key": "testUserEmail",
      "value": "qa-user@medimapa.test"
    },
    {
      "key": "testUserPassword",
      "value": "Test123!"
    },
    {
      "key": "testUserRole",
      "value": "USER"
    }
  ],
  "item": [
    {
      "name": "Registro de usuario en ms-usuarios",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"correo\": \"{{testUserEmail}}\",\n  \"passwordHash\": \"{{testUserPassword}}\",\n  \"rol\": \"{{testUserRole}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/registro",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "usuarios",
            "registro"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Body contains registro success', function () {",
              "    pm.expect(pm.response.text()).to.include('Usuario registrado');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Login de usuario en ms-usuarios",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"correo\": \"{{testUserEmail}}\",\n  \"password\": \"{{testUserPassword}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/usuarios/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "usuarios",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is valid JSON', function () {",
              "    pm.response.to.be.json;",
              "});",
              "pm.test('Response contains token and mensaje', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('mensaje');",
              "    pm.expect(jsonData).to.have.property('token');",
              "    pm.expect(jsonData.mensaje).to.eql('Login exitoso');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
